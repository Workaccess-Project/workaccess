# Backend environment example (staging/prod ready)

# Server
PORT=3000
NODE_ENV=development

# Auth mode:
# DEV = allows demo fallback headers (x-company-id, x-role)
# JWT_ONLY = requires Authorization: Bearer <token>
AUTH_MODE=DEV

# Production CORS whitelist (comma-separated)
# Used only when NODE_ENV=production
# Example:
# CORS_ORIGINS=https://app.workaccess.cz,https://staging.workaccess.cz
CORS_ORIGINS=

# Optional build metadata (safe to expose)
# Git commit SHA of deployed build
BUILD_SHA=

# Deployment/build time (ISO 8601 UTC recommended)
BUILD_TIME=
